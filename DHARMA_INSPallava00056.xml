            <div type="edition" xml:lang="san-Latn" rendition="class:siddhamātr̥kā maturity:undetermined">
                <!--Update reading (this is Hultzsch's reading)-->
                <!--Check numbering compared to Hultzsch-->
                
                <p>
                    <milestone n="2" unit="zone" type="pagelike"/>
                    <label>1st chapel</label>
                    <lb n="1"/><gap reason="lost"/>
                </p>
                
                <p>
                    <milestone n="2" unit="zone" type="pagelike"/>
                    <label>2nd chapel</label>
                    <lb n="2"/>śrī-Atyantakāmaḥ śrī-Amitramallaḥ
                </p>
                
                <p>
                    <milestone n="3" unit="zone" type="pagelike"/>
                    <label>3rd chapel</label>
                    <lb n="3"/>śrī-guṇavinītaḥ śrī-Aparājitaḥ
                </p>
                
                <p>
                    <milestone n="4" unit="zone" type="pagelike"/>
                    <label>4th chapel</label>
                    <lb n="4"/>śrī-Avani-divākaraḥ śrī-Ūrjitaḥ
                </p>
                <p>
                    <milestone n="5" unit="zone" type="pagelike"/>
                    <label>5th chapel</label>
                    <lb n="5"/>śrī-Udita-prabhāvaḥ śrī-Udita-kīrttiḥ
                </p>
                
                <p>
                    <milestone n="6" unit="zone" type="pagelike"/>
                    <label>6th chapel</label>
                    <lb n="6"/>śrī-kalaṁkarahitaḥ śrī-kalāsamudraḥ
                </p>
                
                <p>
                    <milestone n="7" unit="zone" type="pagelike"/>
                    <label>7th chapel</label>
                    <lb n="7"/>śrī-Ugra<unclear>vī</unclear>ryyaḥ śrī-Uditoditaḥ
                </p>
                
                <p>
                    <milestone n="8" unit="zone" type="pagelike"/>
                    <label>8th chapel</label>
                    <lb n="8"/>śrī-Atyudāraḥ śrī-Anunayasā<unclear>ddhyaḥ</unclear>
                </p>
                
                <p>
                    <milestone n="9" unit="zone" type="pagelike"/>
                    <label>9th chapel</label>
                    <lb n="9"/>śrī-Unnatarāmaḥ śrī-Ugrapratā<unclear>paḥ</unclear>
                </p>
                
                <p>
                    <milestone n="10" unit="zone" type="pagelike"/>
                    <label>10th chapel</label>
                    <lb n="10"/>śrī-Āhavadhīraḥ śrīĀha<unclear>vakesarī</unclear>
                </p>
                
                <p>
                    <milestone n="11" unit="zone" type="pagelike"/>
                    <label>11th chapel</label>
                    <lb n="11"/>śrī <gap reason="lost" quantity="5" unit="character"/> śrī-kālakopaḥ
                </p>
                
                <p>
                    <milestone n="12" unit="zone" type="pagelike"/>
                    <label>12th chapel</label>
                    <lb n="12"/>śrīr-Āvaravikramaḥ śrī-rivannānukampī<surplus>ḥ</surplus>
                </p>
                
                <p>
                    <milestone n="13" unit="zone" type="pagelike"/>
                    <label>13th chapel</label>
                    <lb n="13"/>śrī-cakravarttī śrī-<unclear>cāpa</unclear>dvitīya<unclear>ḥ</unclear>
                </p>
                
                <p>
                    <milestone n="14" unit="zone" type="pagelike"/>
                    <label>14th chapel</label>
                    <lb n="14"/>śrī-Amoghabāṇaḥ śrī-Asahyamārggaṇaḥ
                </p>
                
                <p>
                    <milestone n="15" unit="zone" type="pagelike"/>
                    <label>15th chapel</label>
                    <lb n="15"/>śrī-Ugrasāyakaḥ śrī-Uddhataviśikhaḥ
                </p>
                
                <p>
                    <milestone n="16" unit="zone" type="pagelike"/>
                    <label>16th chapel</label>
                    <lb n="16"/>śrī-bhīmakārmmukaḥ śrī-bhīṣaṇacāpa<unclear>ḥ</unclear>
                </p>
                
                <p>
                    <milestone n="17" unit="zone" type="pagelike"/>
                    <label>17th chapel</label>
                    <lb n="17"/>śrī-Avismitaḥ śrī-Amitrāśaniḥ
                </p>
                
                <p>
                    <milestone n="18" unit="zone" type="pagelike"/>
                    <label>18th chapel</label>
                    <lb n="18"/>śrī-Iṣṭavarṣaḥ śrī-Indralīlaḥ
                </p>                
                
                <p>
                    <milestone n="19" unit="zone" type="pagelike"/>
                    <label>19th chapel</label>
                    <lb n="19"/>śrī-Amitra<unclear>marddanaḥ<!--possibly one more lost here--> śrī</unclear>-Ājimarddanaḥ
                </p>
                <p>
                    <milestone n="20" unit="zone" type="pagelike"/>
                    <label>20th chapel</label>
                    <lb n="20"/>śrī-duṣṭadamanaḥ śrī-durutsahaḥ
                </p>
