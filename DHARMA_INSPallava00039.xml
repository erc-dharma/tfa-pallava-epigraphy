        <body>
            
            <div type="edition" xml:lang="san-Latn" rendition="class:grantha maturity:regional">
                
                <div type="textpart" n="A"><head>First storey, north side</head>
                    <p>
                        <lb n="A1"/>śrī-narasiṁhaḥ
                    </p>
                </div>
                
                <div type="textpart" n="B"><head>First storey, east side</head>
                    <p>
                        <lb n="B1"/>p<choice><sic>ri</sic><corr>r</corr></choice><choice><sic>dh</sic><corr>th</corr></choice>iv<choice><sic>i</sic><corr>ī</corr></choice>-sāraḥ śrī-bharaḥ
                        <lb n="B2"/>bhuvana-bhājanaḥ
                    </p>
                </div>
                
                <div type="textpart" n="C"><head>First storey, south side</head>
                    <p>
                        <lb n="C1"/><unclear>śr</unclear>ī-meghaḥ trailokya-varddhanaḥ vidhiḥ
                    </p>
                    <p>
                        <lb n="C2"/>Atyantakāmaḥ Aneko<choice><sic>bh</sic><corr>p</corr></choice>āyaḥ
                    </p></div>
                
                <div type="textpart" n="D"><head>Second storey, north side</head>
                    <p>
                        <lb n="D1.1"/>sthira-bhaktiḥ madanābhirāmaḥ
                        <lb n="D1.2"/>vidhi<supplied reason="omitted">ḥ</supplied>
                    </p>
                    <p>
                        <lb n="D2.1"/>śrī-narasiṁhaḥ bhuvana-bhājanaḥ śrī-meghaḥ 
                        <lb n="D2.2"/>Apratihata-śāsana<supplied reason="omitted">ḥ</supplied>
                    </p>
                    
                    <p>
                        <lb n="D3.1"/>kāmalaḷitaḥ Ameyamāyaḥ
                        <lb n="D3.2"/>sakalakalyāṇaḥ
                    </p>
                    
                    <p>
                        <lb n="D4.1"/>nayanamanoharaḥ vāmaḥ
                        <lb n="D4.2"/>Atimānaḥ
                    </p>
                </div>
                
                <div type="textpart" n="E"><head>Second storey, east side</head>
                    <p>
                        <lb n="E1.1"/>vāmaḥ
                        <lb n="E1.2"/>parā<choice><sic>bh</sic><corr>p</corr></choice>araḥ
                    </p>
                    <p>
                        <lb n="E2.1"/>Anupamaḥ
                        <lb n="E2.2"/>nayā<unclear>ṅku</unclear>ra<supplied reason="omitted">ḥ</supplied>
                    </p>
                </div>
                
                <div type="textpart" n="F"><head>Second storey, south side</head>
                    <p>
                        <lb n="F1"/>laḷitaḥ
                    </p>
                    <p>
                        <lb n="F2.1"/>nayanamanoharaḥ
                        <lb n="F2.2"/>sarvvatobhadraḥ
                    </p>
                    <p>
                        <lb n="F3.1"/>śrīnidhiḥ
                        <lb n="F3.2"/>niruttaraḥ
                    </p>
                    <p>
                        <lb n="F4.1"/>vidhiḥ
                        <lb n="F4.2"/>vibhrāntaḥ
                    </p>
                </div>
                
                <div type="textpart" n="G"><head>Second storey, west side</head>
                    
                    <p>
                        <lb n="G1"/>satya-parākramaḥ
                        <lb n="G2"/>parāvaraḥ
                    </p>
                    
                </div>
                
                <div type="textpart" n="H"><head>Third storey, east side</head>
                    
                    <p>
                        <lb n="H1"/>śrī-Atyanta-kāma-pallaveśvara-gṛhaM <g ref="sym:doubleBar" type="punctuation">.</g>
                        <lb n="H2"/>raṇa-jayaḥ
                    </p>
                </div>
            </div>
            
