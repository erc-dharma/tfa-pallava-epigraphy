                        <rdg source="bib:Hultzsch1890_01 bib:Hultzsch1909-1910_01">A<unclear>nugra</unclear>śīla<supplied reason="omitted">ḥ <g ref="sym:doubleBar" type="punctuation">.</g></supplied></rdg>
